# Backend Environment Variables Template
# Copy this file to .env and fill in actual values

# === Database Configuration ===
DB_HOST=localhost
DB_PORT=5432
DB_USER=kinship
DB_PASS=kinship_password
DB_NAME=kinship_db

# === JWT / Authentication ===
JWT_SECRET=change-this-to-a-strong-random-secret-key
JWT_EXPIRES=7d

# === Node Environment ===
NODE_ENV=development
API_PORT=3000

# === AWS S3 (File uploads) ===
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET=kinship-uploads

# === Razorpay (Payments) ===
RAZORPAY_KEY_ID=your_razorpay_key_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# === Firebase (Push Notifications) ===
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# === Email Service (Optional) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# === Logging ===
LOG_LEVEL=debug
LOG_FORMAT=json

# === CORS ===
CORS_ORIGIN=http://localhost:8081,http://localhost:8082,http://localhost:19006
